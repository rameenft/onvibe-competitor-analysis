# Apify (https://console.apify.com/account/integrations for your token)
APIFY_API_TOKEN=

# Apify actor IDs — verify these still match the intended actor in the Apify
# Store before a real run; swap freely if a better/cheaper actor exists.
APIFY_IG_PROFILE_ACTOR_ID=apify/instagram-profile-scraper
APIFY_IG_POST_ACTOR_ID=apify/instagram-post-scraper
APIFY_TIKTOK_PROFILE_ACTOR_ID=clockworks/tiktok-profile-scraper
APIFY_TIKTOK_POST_ACTOR_ID=clockworks/tiktok-scraper
APIFY_LINKEDIN_PROFILE_ACTOR_ID=scrapier/linkedin-company-scraper-actor
APIFY_LINKEDIN_POST_ACTOR_ID=harvestapi/linkedin-company-posts
APIFY_SOCIALBLADE_ACTOR_ID=amrameng/socialblade-scraper

# Supabase (Project Settings -> API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# Internal
WORKER_POLL_INTERVAL_MS=5000
APP_BASE_URL=http://localhost:3000
